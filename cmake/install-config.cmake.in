@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(fmt)
find_dependency(nlohmann_json)
find_dependency(RapidJSON)

# BinaryNinjaCore _library_ presence is optional, so we use find_package
# instead of find_dependency here
find_package(BinaryNinjaCore
    HINTS ${CMAKE_CURRENT_LIST_DIR}/../../..
)

include("${CMAKE_CURRENT_LIST_DIR}/BinjaPluginFunctions.cmake")

include("${CMAKE_CURRENT_LIST_DIR}/BinaryNinjaAPITargets.cmake")

# Set this so that the UI API can pull it onto its own target with
# target_include_directory
set_and_check(ui_includedir "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@/ui")
set_target_properties(binaryninjaapi
    PROPERTIES BinaryNinjaUI_INCLUDE_DIR "${ui_includedir}"
)
